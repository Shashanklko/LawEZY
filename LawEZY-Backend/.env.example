# --- DATABASE ---
TIDB_URL=jdbc:mysql://<host>:4000/lawezy?useSSL=true&serverTimezone=UTC
TIDB_USER=<user>
TIDB_PASSWORD=<password>
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lawezy_main

# --- SECURITY ---
JWT_SECRET=<secure-512-bit-string>
INTERNAL_SECRET=<secure-internal-grid-secret>

# --- INSTITUTIONAL SERVICES ---
GMAIL_CLIENT_ID=<id>
GMAIL_CLIENT_SECRET=<secret>
GMAIL_REFRESH_TOKEN=<token>
GMAIL_USER_EMAIL=<email>

GOOGLE_AI_API_KEY=<gemini-api-key>

RAZORPAY_KEY_ID=<rzp_live_xxx>
RAZORPAY_KEY_SECRET=<secret>

SUPABASE_URL=<url>
SUPABASE_KEY=<service-role-key>
SUPABASE_BUCKET=legal-docs

# --- DEPLOYMENT ---
ALLOWED_ORIGINS=https://lawezy.vercel.app
MESSENGER_URL=http://localhost:8081
JPA_DDL=validate
